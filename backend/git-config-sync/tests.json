{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unauthorized without token",
      "method": "POST",
      "path": "/",
      "body": { "repo_url": "https://github.com/example/repo.git" },
      "expectedStatus": 401
    },
    {
      "name": "Missing repo_url returns 401 (token required)",
      "method": "POST",
      "path": "/",
      "body": { "auth_mode": "token" },
      "expectedStatus": 401
    },
    {
      "name": "Invalid auth_mode returns 401 (token required)",
      "method": "POST",
      "path": "/",
      "body": { "repo_url": "https://github.com/example/repo.git", "auth_mode": "magic" },
      "expectedStatus": 401
    }
  ]
}