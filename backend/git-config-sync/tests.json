{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unauthorized without token",
      "method": "POST",
      "path": "/",
      "headers": {},
      "body": {},
      "expectedStatus": 401
    },
    {
      "name": "Missing repo_url returns error",
      "method": "POST",
      "path": "/",
      "headers": {"X-Admin-Token": ""},
      "body": {"auth_mode": "token", "auth_value": "tok"},
      "expectedStatus": 400,
      "expectedBody": {"error": "repo_url is required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Invalid auth_mode returns error",
      "method": "POST",
      "path": "/",
      "headers": {"X-Admin-Token": ""},
      "body": {"repo_url": "https://github.com/example/repo.git", "auth_mode": "magic"},
      "expectedStatus": 400,
      "expectedBody": {"error": "auth_mode must be token, ssh_key or askpass"},
      "bodyMatcher": "partial"
    }
  ]
}
